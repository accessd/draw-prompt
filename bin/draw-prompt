#!/bin/sh
set -eu

script="$0"

while [ -L "$script" ]; do
	dir=$(CDPATH= cd -- "$(dirname -- "$script")" && pwd)
	target=$(readlink "$script")
	case "$target" in
		/*) script="$target" ;;
		*) script="$dir/$target" ;;
	esac
done

dir=$(CDPATH= cd -- "$(dirname -- "$script")" && pwd)
exec bun "$dir/../src/cli.ts" "$@"

